# ============================================================================
# PRISM - Environment Variables Template
# ============================================================================
#
# WHAT THIS FILE IS:
# This is a TEMPLATE showing what environment variables Prism needs.
# Copy this file to ".env" and fill in your actual values.
#
# HOW TO USE:
# 1. Copy this file:    cp .env.example .env
# 2. Edit .env:         Fill in your API keys and passwords
# 3. NEVER commit .env: It contains secrets (it's in .gitignore)
#
# WHERE TO GET API KEYS:
# See docs/SETUP_GUIDE.md for detailed instructions on getting each API key.
#
# SECURITY:
# - Never commit this file with real values
# - Use strong, unique passwords
# - Keep API keys secret
#
# ============================================================================


# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL database connection settings.
# If using Docker, the hostname should be "db" (the service name).
# If running locally, use "localhost".
# ============================================================================

# Database connection string
# Format: postgresql://username:password@hostname:port/database
DATABASE_URL=postgresql://prism:your_secure_password_here@db:5432/prism

# Database password (used by Docker Compose)
# IMPORTANT: Change this to a strong, unique password!
# Minimum 16 characters recommended. Use a password generator.
DB_PASSWORD=your_secure_password_here


# ============================================================================
# REDIS CACHE (Optional but Recommended)
# ============================================================================
# Redis improves performance by caching frequently-accessed data.
# If using Docker, the hostname should be "redis" (the service name).
# ============================================================================

REDIS_URL=redis://redis:6379


# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
# Core application configuration.
# ============================================================================

# Environment: "development" or "production"
NODE_ENV=production

# Port the app runs on (inside the container)
PORT=3000

# Public URL where users access the dashboard
# For local use: http://localhost:3000
# For network access: http://192.168.1.100:3000 (use your server's IP)
APP_URL=http://localhost:3000


# ============================================================================
# SECURITY SECRETS
# ============================================================================
# These MUST be random, unique strings. Never share them!
#
# HOW TO GENERATE:
# Option 1: Visit https://www.random.org/strings/ (32+ characters)
# Option 2: Run: openssl rand -hex 32
# Option 3: Run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ============================================================================

# Used to encrypt session cookies
# CHANGE THIS! Use a random 32+ character string
SESSION_SECRET=generate_a_random_32_character_string_here

# Used to encrypt user PINs in the database
# CHANGE THIS! Use a different random 32+ character string
PIN_ENCRYPTION_KEY=generate_another_random_32_character_string


# ============================================================================
# GOOGLE CALENDAR INTEGRATION
# ============================================================================
# For syncing Google Calendar events.
#
# HOW TO GET THESE:
# 1. Go to: https://console.cloud.google.com
# 2. Create a new project (or select existing)
# 3. Enable "Google Calendar API"
# 4. Go to "Credentials" > "Create Credentials" > "OAuth 2.0 Client ID"
# 5. Application type: "Web application"
# 6. Add authorized redirect URI (see below)
# 7. Copy the Client ID and Client Secret
#
# DETAILED GUIDE: docs/SETUP_GUIDE.md#google-calendar
# ============================================================================

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback


# ============================================================================
# APPLE ICLOUD/CALENDAR INTEGRATION
# ============================================================================
# For syncing Apple Calendar events and iCloud Photos.
#
# IMPORTANT: Use an APP-SPECIFIC PASSWORD, not your regular Apple password!
#
# HOW TO GET APP-SPECIFIC PASSWORD:
# 1. Go to: https://appleid.apple.com
# 2. Sign in with your Apple ID
# 3. Go to "Security" section
# 4. Click "App-Specific Passwords"
# 5. Click "+" to generate a new password
# 6. Name it "Prism" (or "Home Dashboard")
# 7. Copy the generated password
#
# NOTE: You must have 2-factor authentication enabled on your Apple account.
# ============================================================================

APPLE_ID=your-apple-id@icloud.com
APPLE_APP_PASSWORD=your-app-specific-password


# ============================================================================
# MICROSOFT INTEGRATION (To Do, OneDrive)
# ============================================================================
# For syncing Microsoft To Do tasks and OneDrive photos.
#
# HOW TO GET THESE:
# 1. Go to: https://portal.azure.com
# 2. Search for "App registrations"
# 3. Click "New registration"
# 4. Name: "Prism" (or "Home Dashboard")
# 5. Supported account types: "Personal Microsoft accounts only"
# 6. Redirect URI: Web, http://localhost:3000/api/auth/microsoft/callback
# 7. After creation, copy "Application (client) ID"
# 8. Go to "Certificates & secrets" > "New client secret"
# 9. Copy the secret value (shown only once!)
# 10. Go to "API permissions" > Add:
#     - Microsoft Graph > Tasks.ReadWrite
#     - Microsoft Graph > Files.Read
#
# DETAILED GUIDE: docs/SETUP_GUIDE.md#microsoft
# ============================================================================

MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/auth/microsoft/callback


# ============================================================================
# WEATHER (OpenWeatherMap)
# ============================================================================
# For displaying current weather and forecasts.
#
# HOW TO GET API KEY:
# 1. Go to: https://openweathermap.org/api
# 2. Sign up for a free account
# 3. Go to "API Keys" in your account
# 4. Copy your API key (or generate a new one)
#
# FREE TIER: 1,000 API calls per day (plenty for a family dashboard!)
# ============================================================================

OPENWEATHER_API_KEY=your-openweathermap-api-key

# Your location for weather
# Format: City,State,Country (use ISO country codes)
# Examples:
#   - Springfield,IL,US
#   - London,GB
#   - Tokyo,JP
WEATHER_LOCATION=Springfield,IL,US


# ============================================================================
# ENPHASE SOLAR MONITORING (Optional)
# ============================================================================
# For displaying solar panel production data.
# Leave blank if you don't have Enphase solar panels.
#
# HOW TO GET THESE:
# 1. Go to: https://developer-v4.enphase.com
# 2. Register for an API account
# 3. Create a new application
# 4. Copy your API key
# 5. Find your System ID in the Enphase Enlighten app or website
#
# DETAILED GUIDE: docs/SETUP_GUIDE.md#enphase-solar
# ============================================================================

ENPHASE_API_KEY=your-enphase-api-key
ENPHASE_SYSTEM_ID=your-enphase-system-id


# ============================================================================
# SONOS MUSIC CONTROL (Optional)
# ============================================================================
# For controlling Sonos speakers from the dashboard.
# Leave blank if you don't have Sonos speakers.
#
# HOW TO GET THESE:
# 1. Go to: https://developer.sonos.com
# 2. Apply for developer access (may take 1-2 business days)
# 3. Once approved, create a new integration
# 4. Copy Client ID and Client Secret
# 5. Add redirect URI (see below)
#
# NOTE: Sonos requires developer account approval.
# ALTERNATIVE: For local network control without Sonos API, we can use
# the node-sonos library instead (doesn't require these credentials).
# ============================================================================

SONOS_CLIENT_ID=your-sonos-client-id
SONOS_CLIENT_SECRET=your-sonos-client-secret
SONOS_REDIRECT_URI=http://localhost:3000/api/auth/sonos/callback


# ============================================================================
# FUTURE INTEGRATIONS (Leave blank for now)
# ============================================================================
# These are placeholders for future integrations.
# Uncomment and fill in when you're ready to use them.
# ============================================================================

# Homebridge (Smart Home Control)
# HOMEBRIDGE_URL=http://homebridge-host:8581
# HOMEBRIDGE_USERNAME=admin
# HOMEBRIDGE_PASSWORD=your-homebridge-password

# Life360 (Family Location - alternative to Find My)
# LIFE360_USERNAME=your-email@example.com
# LIFE360_PASSWORD=your-life360-password
