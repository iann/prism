# ============================================================================
# PRISM - Family Dashboard
# Development Dockerfile
# ============================================================================
#
# WHAT THIS FILE DOES:
# This Dockerfile creates a development environment with hot-reloading.
# Unlike the production Dockerfile, this one:
#   - Includes all development dependencies
#   - Runs "npm run dev" for live reloading
#   - Keeps source code mounted from your local machine
#
# WHY A SEPARATE FILE:
# Development and production have different needs:
#   - Dev: Fast iteration, debugging tools, source maps
#   - Prod: Small size, security, performance
#
# ============================================================================

FROM node:20-alpine

# Install system dependencies
RUN apk add --no-cache libc6-compat

WORKDIR /app

# Copy package files
COPY package.json package-lock.json* ./

# Install ALL dependencies (including devDependencies)
# In production, we use --omit=dev, but we need dev deps for development
RUN npm ci

# Don't copy source code - it will be mounted via docker-compose volumes
# This allows hot reloading when you edit files on your host machine

# Expose the development server port
EXPOSE 3000

# Set development environment
ENV NODE_ENV=development
ENV NEXT_TELEMETRY_DISABLED=1

# Start the development server with hot reloading
CMD ["npm", "run", "dev"]
