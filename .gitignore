# ============================================================================
# PRISM - Git Ignore Configuration
# ============================================================================
#
# WHAT THIS FILE DOES:
# Lists files and folders that Git should NOT track.
# These files are either:
#   - Generated by tools (node_modules, .next)
#   - Contain secrets (.env)
#   - User-specific (IDE settings)
#   - Large binary files (uploads, caches)
#
# NEVER COMMIT:
# - .env files (contain API keys and passwords!)
# - node_modules (too large, recreatable from package.json)
# - Build outputs (recreatable by running npm run build)
#
# ============================================================================


# ============================================================================
# ENVIRONMENT & SECRETS
# ============================================================================
# CRITICAL: Never commit files containing API keys, passwords, or secrets!
# ============================================================================

# Environment variables - contains all your secrets
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local

# Keep the example file (it has no real secrets)
!.env.example

# Claude Code settings (may contain credentials in allowed commands)
.claude/settings.local.json


# ============================================================================
# DEPENDENCIES
# ============================================================================
# Installed packages - too large to commit, recreated with npm install
# ============================================================================

node_modules/


# ============================================================================
# BUILD OUTPUTS
# ============================================================================
# Generated files from building the app - recreated with npm run build
# ============================================================================

# Next.js build output
.next/
out/

# TypeScript build info (speeds up recompilation)
*.tsbuildinfo

# Next.js standalone output
.next/standalone/


# ============================================================================
# RUNTIME & CACHE FILES
# ============================================================================
# Files created while the app runs - not needed in source control
# ============================================================================

# Dependency cache
.npm
.pnpm-store/

# Next.js cache
.cache/

# Photo cache (downloaded from iCloud/OneDrive)
cache/

# Uploaded files (user uploads, photos, etc.)
uploads/


# ============================================================================
# LOGS
# ============================================================================
# Log files created during development and runtime
# ============================================================================

npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Runtime logs
logs/
*.log


# ============================================================================
# TESTING
# ============================================================================
# Test-related files and outputs
# ============================================================================

# Test coverage reports
coverage/
.nyc_output/

# Playwright test results
test-results/
playwright-report/
playwright/.cache/


# ============================================================================
# OPERATING SYSTEM FILES
# ============================================================================
# Hidden files created by macOS and Windows
# ============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini

# Linux
*~


# ============================================================================
# IDE & EDITOR FILES
# ============================================================================
# User-specific IDE settings (each developer has their own preferences)
# ============================================================================

# VS Code
# Note: We keep .vscode/settings.json and .vscode/extensions.json
#       for shared project settings, but ignore user-specific files
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json

# JetBrains IDEs (WebStorm, IntelliJ)
.idea/
*.iml
*.ipr
*.iws

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
.#*


# ============================================================================
# DOCKER
# ============================================================================
# Docker-related files that shouldn't be committed
# ============================================================================

# Docker volumes data (created by docker-compose)
# The actual data is stored in Docker volumes, not these directories
docker-data/


# ============================================================================
# MISCELLANEOUS
# ============================================================================
# Other files that shouldn't be tracked
# ============================================================================

# Vercel deployment files
.vercel

# Drizzle generated files (we commit migrations, but not generated artifacts)
drizzle/meta/

# Local database file (if using SQLite for development)
*.db
*.sqlite
*.sqlite3

# Temporary files
tmp/
temp/
*.tmp
*.temp

# Reference screenshots (not part of the project)
screenshots/

# Backup files
*.bak
*.backup

# Archive files
*.zip
*.tar.gz
*.rar
